# App
APP_ENV=local
APP_NAME=uarb-matter-mail-agent
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Mailgun (Inbound + Send)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=UARB Agent <uarb-agent@mg.yourdomain.com>

# Security (Mailgun webhook signing)
MAILGUN_WEBHOOK_SIGNING_KEY=xxxxxxxxxxxxxxxxxxxx

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Scraping
UARB_BASE_URL=https://uarb.novascotia.ca/fmi/webd/UARB15

# Limits
MAX_DOCS=10
MAX_ZIP_MB=20